# --------------------------------------------------------------------------
# Secrets and environment
# --------------------------------------------------------------------------
.env
.env.*
!.env.example

# --------------------------------------------------------------------------
# Data files
# --------------------------------------------------------------------------
# Block the database (regenerated locally by the pipeline) and the
# intermediate "clean" exports. We DO commit the two final CSVs that the
# dashboard reads from, so the app works on a fresh clone.
*.db
*.sqlite
*.sqlite3
*.sqlite-journal
*.db-journal
*.db-wal
*.db-shm
data/raw/
data/exports/articles_clean.csv
data/exports/entities_clean.csv

# --------------------------------------------------------------------------
# Logs and run artifacts
# --------------------------------------------------------------------------
logs/
*.log

# --------------------------------------------------------------------------
# Python
# --------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
build/
dist/

# Virtual environments
.venv/
venv/
ENV/
env/

# --------------------------------------------------------------------------
# Jupyter
# --------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# --------------------------------------------------------------------------
# Hugging Face model cache (very large, regenerated on first run)
# --------------------------------------------------------------------------
.cache/
huggingface/

# --------------------------------------------------------------------------
# IDE and editors
# --------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --------------------------------------------------------------------------
# OS
# --------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --------------------------------------------------------------------------
# Tableau (keep .twb / .twbx in repo, ignore generated extracts)
# --------------------------------------------------------------------------
*.tde
*.hyper
.tableau-tmp/
